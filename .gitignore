src/shared/**/*.d.ts
!src/shared/**/*.ts
src/main/**/*.js
src/main/**/*.js.map
!src/main/**/*.ts
src/renderer/**/*.js
src/renderer/**/*.js.map
!src/renderer/**/*.ts

