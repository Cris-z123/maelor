{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "outDir": "./dist/renderer",
    "types": ["vite/client"],
    "jsx": "react-jsx",
    "allowImportingTsExtensions": false
  },
  "include": [
    "src/renderer/main.tsx",
    "src/renderer/onboarding.tsx",
    "src/renderer/global.d.ts",
    "src/renderer/app/App.tsx",
    "src/renderer/app/OnboardingApp.tsx",
    "src/renderer/app/OnboardingFlow.tsx",
    "src/renderer/app/mvpApi.ts",
    "src/renderer/styles/**/*",
    "src/shared/types/mvp.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/main",
    "src/renderer/components",
    "src/renderer/hooks",
    "src/renderer/lib",
    "src/renderer/services",
    "src/renderer/stores"
  ]
}
